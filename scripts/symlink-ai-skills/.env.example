# .env.example

# Base directory used to resolve relative entries in list files.
# If you use relative paths in your list files (recommended for sharing),
# set LIST_BASE_DIR to a common prefix. Defaults to $HOME.
#LIST_BASE_DIR="$HOME"

# Comma- or colon-separated list of destination skill directories.
# Example: TARGET_DIRS="$HOME/.copilot/skills:$HOME/.claude/skills"
#TARGET_DIRS="$HOME/.copilot/skills"

# Option A: point to a newline-separated skills list file (preferred)
#SKILLS_LIST_FILE="/Users/you/Code/VendorRepos/skill-list.txt"

# Option B: inline list of source skill directories (comma or colon separated)
#SKILLS_DIRS="/Users/you/Code/VendorRepos/skill-a,/Users/you/Code/VendorRepos/skill-b"

# Optional per-component list files. If provided, these should be newline-separated paths.
#INSTRUCTIONS_LIST_FILE="/path/to/instructions-list.txt"
#HOOKS_LIST_FILE="/path/to/hooks-list.txt"
#AGENTS_LIST_FILE="/path/to/agents-list.txt"

# You can also limit which components to include via the -T flag (comma separated):
# e.g. -T "skills,instructions" (defaults to all: skills,instructions,hooks,agents)

# Optional per-component destination directories (comma- or colon-separated).
# If set, these override the shared `TARGET_DIRS` for their component.
# Examples:
#SKILLS_TARGET_DIRS="$HOME/.copilot/skills:$HOME/.copilot/skills-local"
#INSTRUCTIONS_TARGET_DIRS="$HOME/.copilot/instructions"
#HOOKS_TARGET_DIRS="$HOME/.copilot/hooks"
#AGENTS_TARGET_DIRS="$HOME/.copilot/agents"

# Precedence when resolving where to link a component:
# 1) Component-specific env var (e.g. INSTRUCTIONS_TARGET_DIRS)
# 2) CLI override via -t
# 3) Global TARGET_DIRS
# 4) Default: $HOME/.copilot/skills



# Note: older COPILOT_SKILLS_DEST is deprecated; use TARGET_DIRS for multiple targets.