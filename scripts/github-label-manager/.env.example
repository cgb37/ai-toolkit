# Project Configuration
PROJECT_NAME=github-label-manager
PROJECT_VERSION=1.0.0
ENVIRONMENT=development

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_SIZE=10485760  # 10MB in bytes
LOG_RETENTION_DAYS=14

# GitHub Configuration
GITHUB_ORG=your-org-or-username
GITHUB_REPO=your-repo-name
# GITHUB_TOKEN or GH_TOKEN must be set in environment or .env
# GITHUB_TOKEN=your_github_token_here

# GitHub Configuration (for git_setup.sh)
GITHUB_VISIBILITY=public  # public or private

# Script Paths (override if needed)
SCRIPT_DIR=./scripts
OUTPUT_DIR=./output
TEMP_DIR=/tmp

# Feature Flags
DEBUG_MODE=false
DRY_RUN=false
