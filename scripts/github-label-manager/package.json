{
  "name": "github-label-manager",
  "version": "1.0.0",
  "description": "GitHub Label Manager for conventional commit labels",
  "scripts": {
    "start": "bash scripts/github_label_manager.sh --help",
    "test": "bash tests/test_github_label_manager.sh",
