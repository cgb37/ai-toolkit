# .env.example
# Destination directory for Copilot skills
COPILOT_SKILLS_DEST="$HOME/.copilot/skills"

# Option A: point to a newline-separated skills list file
#SKILLS_LIST_FILE="/Users/you/Code/VendorRepos/skill-list.txt"

# Option B: inline list (comma or colon separated)
#SKILLS_DIRS="/Users/you/Code/VendorRepos/skill-a,/Users/you/Code/VendorRepos/skill-b"